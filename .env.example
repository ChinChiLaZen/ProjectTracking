# See docker-compose.yml for local Postgres/Redis.
DATABASE_URL="postgresql://postgres:dev@localhost:5432/workos?schema=public"
REDIS_URL="redis://localhost:6379"

NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# NextAuth Email (magic link) provider + Session 15's notification mailer
# (lib/mailer.ts) — both point at the same SMTP transport. docker-compose's
# maildev service catches everything sent here; view it at localhost:1080.
EMAIL_SERVER="smtp://user:pass@localhost:1025"
EMAIL_FROM="WorkOS <noreply@example.com>"

# Session 16 file attachments: lib/storage/index.ts picks S3 vs local-disk
# automatically — set S3_BUCKET (+ region/keys) for S3, or leave it unset
# to use LOCAL_UPLOAD_DIR (a plain folder on disk, gitignored) for local dev.
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
LOCAL_UPLOAD_DIR="./.uploads"
