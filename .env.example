# See docker-compose.yml for local Postgres/Redis.
DATABASE_URL="postgresql://postgres:dev@localhost:5432/workos?schema=public"
REDIS_URL="redis://localhost:6379"

NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# NextAuth Email (magic link) provider
EMAIL_SERVER="smtp://user:pass@localhost:1025"
EMAIL_FROM="WorkOS <noreply@example.com>"

# Phase 3 (attachments) — unused until then, documented here per §2
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
