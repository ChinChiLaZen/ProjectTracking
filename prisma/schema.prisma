generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Shared by Membership (org-level) and BoardMembership (board-level, §5).
// A user's org Role is their default board role in that org's boards;
// an explicit BoardMembership row overrides it. GUEST never gets a
// default — guests only have access via an explicit BoardMembership.
enum Role {
  OWNER
  ADMIN
  MEMBER
  GUEST
}

model Organization {
  id        String   @id @default(cuid(2))
  name      String
  createdAt DateTime @default(now())

  memberships Membership[]
  workspaces  Workspace[]
  boards      Board[]

  @@map("organizations")
}

model User {
  id            String    @id @default(cuid(2))
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  accounts         Account[]
  sessions         Session[]
  memberships      Membership[]
  boardMemberships BoardMembership[]

  @@map("users")
}

// User × Organization. Carries the user's org-level role, which also
// serves as their default board role within that org (§5).
model Membership {
  id             String   @id @default(cuid(2))
  organizationId String
  userId         String
  role           Role
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("memberships")
}

model Workspace {
  id             String    @id @default(cuid(2))
  organizationId String
  name           String
  createdAt      DateTime  @default(now())
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  boards       Board[]

  @@index([organizationId])
  @@map("workspaces")
}

// Minimal slice for Session 1: enough shape to make requireBoardAccess
// and the cross-org test real. Group/Item/ColumnValue etc. are Phase 1+.
model Board {
  id             String    @id @default(cuid(2))
  organizationId String
  workspaceId    String
  name           String
  createdAt      DateTime  @default(now())
  deletedAt      DateTime?

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  memberships  BoardMembership[]

  @@index([organizationId])
  @@index([workspaceId])
  @@map("boards")
}

// Explicit per-board role, overriding the org-level default (§5).
// Required (not optional) for Guests, who have no default board access.
model BoardMembership {
  id        String   @id @default(cuid(2))
  boardId   String
  userId    String
  role      Role
  createdAt DateTime @default(now())

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
  @@index([userId])
  @@map("board_memberships")
}

// --- NextAuth (@auth/prisma-adapter) required models ---

model Account {
  id                String  @id @default(cuid(2))
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid(2))
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
